{
  "compilerOptions": {
    "target": "ES2021",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "../dist-electron",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "./**/*.ts",
    "../src/game/**/*.ts",
    "../src/shared/**/*.ts"
  ],
  "exclude": ["../src/**/*.test.ts"]
}
